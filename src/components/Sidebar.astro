---
interface Props {
    signTypes: { id: string }[];
}
const { signTypes = [] } = Astro.props;
---

<input id="sidebar-toggle" class="sidebar-toggle" type="checkbox" />

<label for="sidebar-toggle" class="sidebar-grip" aria-label="Toggle Sidebar">
    <span class="grip-icon"></span>
</label>

<aside id="sidebar" class="sidebar">
    <div class="sidebar-content p-3 sm:p-4">
        <h2 class="mb-3 text-lg font-bold sm:mb-4 sm:text-xl">Catalogue</h2>
        <ul>
            {
                signTypes.map((sign) => (
                    <li>
                        <a
                            href={`${import.meta.env.BASE_URL}/signs/${sign.id}`}
                            class="block rounded px-3 py-2 capitalize transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-800 sm:py-2.5"
                        >
                            {sign.id.replace(/-/g, ' ')}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</aside>

<style>
    :root {
        --sidebar-width: min(82vw, 260px);
        --grip-width: 28px;
        --transition-speed: 0.2s;
    }

    .sidebar-toggle {
        display: none;
    }

    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        flex: 0 0 auto;
        width: 0;
        min-height: 100vh;
        background: var(--app-surface-strong);
        border-right: 1px solid var(--app-border);
        overflow: hidden;
        z-index: 100;
        transition: width var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.08);
    }

    .sidebar-content {
        width: var(--sidebar-width);
        height: 100%;
        transform: translateX(-100%);
        transition: transform var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform;
    }

    .sidebar-grip {
        position: fixed;
        top: 50%;
        left: 0;
        transform: translateY(-50%);
        width: var(--grip-width);
        height: 60px;
        background: var(--app-surface-strong);
        border: 1px solid var(--app-border);
        border-left: none;
        border-radius: 0 8px 8px 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 101;
        transition: left var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    }

    .grip-icon::before {
        content: "⋮";
        font-weight: bold;
        color: var(--app-muted);
    }

    .sidebar-toggle:checked ~ .sidebar {
        width: var(--sidebar-width);
    }
    .sidebar-toggle:checked ~ .sidebar .sidebar-content {
        transform: translateX(0);
    }
    .sidebar-toggle:checked ~ .sidebar-grip {
        left: var(--sidebar-width);
    }

    @media (min-width: 1024px) {
        .sidebar {
            position: relative;
            top: auto;
            left: auto;
            bottom: auto;
        }
    }
</style>
