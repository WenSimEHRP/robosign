---
import Sidebar from "../components/Sidebar.astro";
import Header from "../components/Header.svelte";
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;

const templateFiles = import.meta.glob("/templates/**/*.typ", {
    query: "?raw",
    import: "default",
    eager: true,
});
const signTypes = Object.keys(templateFiles).map((path) => {
    const filename = path.split("/").pop() || "";
    return { id: filename.replace(".typ", "") };
});
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Robosign station sign generator" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <script
            defer
            src="https://cloud.umami.is/script.js"
            data-website-id="067cd05f-b395-4813-916c-2063c383685f"></script>
        <title>{title} | Robosign</title>
    </head>
    <body>
        <div class="flex min-h-screen w-full">
            <Sidebar signTypes={signTypes} />
            <main class="flex flex-1 flex-col overflow-hidden">
                <div class="flex-1 overflow-y-auto px-1 py-1 sm:px-6 sm:py-6 lg:p-8">
                    <slot />
                </div>
            </main>
        </div>
    </body>
</html>
