---
import Layout from "../../layouts/Layout.astro";
import SignRenderer from "../../components/SignRenderer.svelte";
import { createTypstCompiler } from "@myriaddreamin/typst.ts";
import { execSync } from "node:child_process";
import { MemoryAccessModel } from "@myriaddreamin/typst.ts/fs/memory";
import path from "node:path";
import { withAccessModel } from "@myriaddreamin/typst.ts/dist/esm/options.init.mjs";
import SimpleBox from "../../components/SimpleBox.astro";
import ParamField from "../../components/ParamField.astro";

export function getStaticPaths() {
    const templateFiles: Record<string, string> = import.meta.glob(
        "/templates/**/*.typ",
        {
            query: "?raw",
            import: "default",
            eager: true,
        },
    );

    return Object.entries(templateFiles).map(([filePath, content]) => {
        const filename = path.basename(filePath);
        const fileDirectory = path.dirname(filePath);

        // Fetch all files in the same directory
        const rawAssetFiles: Record<string, string> = import.meta.glob(
            "/templates/**/*",
            {
                query: "?raw",
                import: "default",
                eager: true,
            },
        );

        const relatedAssetFiles = Object.entries(rawAssetFiles)
            .filter(([assetPath]) => {
                return (
                    path.dirname(assetPath) === fileDirectory &&
                    assetPath !== filePath &&
                    path.dirname(assetPath) !== "/templates"
                );
            })
            .reduce(
                (acc, [assetPath, assetContent]) => {
                    const relativeAssetPath = path.relative(
                        fileDirectory,
                        assetPath,
                    );
                    acc[relativeAssetPath] = assetContent;
                    return acc;
                },
                {} as Record<string, string>,
            );

        // Filter for assets in the current directory and sanitize the keys

        const typeName = filename.replace(".typ", "");
        const absolutePath = path.resolve("." + filePath);

        let lastUpdated = "";
        try {
            lastUpdated = execSync(
                `git log -1 --format=%ai -- "${absolutePath}"`,
            )
                .toString()
                .trim();
        } catch (e) {
            lastUpdated = new Date().toISOString();
        }

        return {
            params: { type: typeName },
            props: {
                sourceCode: content,
                lastUpdated,
                assets: relatedAssetFiles,
            },
        };
    });
}

const { sourceCode, lastUpdated, assets } = Astro.props;
const { type } = Astro.params;
const compiler = createTypstCompiler();
const accessModel = new MemoryAccessModel();
await compiler.init({
    beforeBuild: [withAccessModel(accessModel)],
});
compiler.addSource("/temp.typ", sourceCode);
for (const [assetPath, assetData] of Object.entries(assets)) {
    console.log(`Mapping asset: ${assetPath}`);
    compiler.addSource(`/${assetPath}`, assetData);
}
const rawQueryResult = await compiler.runWithWorld(
    { mainFilePath: "/temp.typ", root: "/" },
    async (world) => {
        const compileResult = await world.compile({ diagnostics: "full" });
        if (compileResult.hasError) {
            return {
                error: "compile_failed",
                diagnostics: compileResult.diagnostics ?? [],
            };
        }
        return await world.query({ selector: "<template_data>" });
    },
);


interface AuthorData {
    name: string;
    ref?: string;
}

const { fonts, authors, published, params } = rawQueryResult[0]["value"];
---

<Layout
    title={`${type} Sign`}
    class="mx-auto h-min grid grid-cols-1 md:grid-cols-2 gap-4 max-w-7xl"
>
    <!-- parameters -->
    <SimpleBox class="grid grid-cols-1 lg:grid-cols-2 gap-4 h-min p-4"
        ><ParamField params={params} /></SimpleBox
    >

    <div class="h-min flex flex-col gap-4">
        <!-- preview -->
        <SimpleBox
            ><SignRenderer
                signTitle={type}
                signSource={sourceCode}
                signParams={params}
                signFonts={fonts}
                signAssets={assets}
                client:only="svelte"
            /></SimpleBox
        >

        <!-- metadata -->
        <SimpleBox class="md:col-start-2 p-4 h-min grid gap-4 grid-cols-2">
            {
                [
                    { label: "Published", value: published },
                    { label: "Last Updated", value: lastUpdated },
                ].map(({ label, value }) => (
                    <div>
                        <h3 class="font-bold tracking-wide uppercase text-xs text-(--app-muted) h-min">
                            {label}
                        </h3>
                        <span class="text-sm text-(--app-fg)">
                            {new Date(value).toLocaleString()}
                        </span>
                    </div>
                ))
            }
            <div>
                <h3
                    class="font-bold tracking-wide uppercase text-xs text-(--app-muted) h-min"
                >
                    Author{authors.length > 1 ? "s" : ""}
                </h3>
                <ul>
                    {
                        authors.map((author: AuthorData) => (
                            <li>
                                {author.ref ? (
                                    <a
                                        href={author.ref}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="text-(--app-fg) hover:underline text-sm"
                                    >
                                        {author.name}
                                    </a>
                                ) : (
                                    <span class="text-(--app-fg) text-sm">
                                        {author.name}
                                    </span>
                                )}
                            </li>
                        ))
                    }
                </ul>
            </div>
        </SimpleBox>
    </div>
</Layout>
